{
  "name": "gemhub-lite",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/ui": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "expo": "~56.0.8",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.16",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-sqlite": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-vision-camera": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "connect": "^3.7.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "expo-atlas": "^0.4.0",
    "patch-package": "^8.0.1",
    "react-doctor": "^0.2.15",
    "react-dom": "19.2.3",
    "serve-sim": "^0.1.38",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "doctor": "bash scripts/doctor.sh",
    "capture:android": "bash scripts/capture-android-evidence.sh",
    "sim": "serve-sim",
    "sim:kill": "serve-sim --kill",
    "sim:camera": "serve-sim camera com.gemhublite.app",
    "postinstall": "patch-package",
    "verify:submission": "bash scripts/verify-submission.sh",
    "doctor:react": "react-doctor"
  },
  "private": true,
  "engines": {
    "node": ">=20.19 <23",
    "npm": ">=10"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-nitro-image"
        ]
      }
    }
  }
}
