    { "file": "docs/research/screenshots/32-click-on-create-collection.png", "use": "Out-of-scope reminder", "doNotCopy": ["Collections creation"] },
    { "file": "docs/research/screenshots/33-create-automate-collection-based-on-filter.png", "use": "Out-of-scope reminder", "doNotCopy": ["Automated collections"] },
