    { "file": "docs/research/screenshots/main-creation/09-main-stone-detail-extra-not-needed.png", "use": "Out-of-scope proof", "doNotCopy": ["Stone detail forms"] }
  ],
  "acceptance": [
    { "id": "A1", "step": "App opens to Camera tab" },
    { "id": "A2", "step": "Capture produces image + routes to Capture Preview" },
    { "id": "A3", "step": "Capture Preview blocks save without normalized SKU" },
    { "id": "A4", "step": "Generate SKU produces SKU-YYYYMMDD-### and unblocks save" },
    { "id": "A5", "step": "Save with new SKU opens Product Detail for that SKU" },
    { "id": "A6", "step": "Saved photo appears in Media tab" },
    { "id": "A7", "step": "Saved product appears in Products tab" },
    { "id": "A8", "step": "Add Photo from Product Detail keeps SKU context" },
    { "id": "A9", "step": "Save with existing SKU appends media only, no duplicate product" },
    { "id": "A10", "step": "Tapping a Media tile opens owning Product Detail" }
  ],
  "invariants": [
    "Every saved media row has a non-null SKU and an owning product.",
    "SKU is immutable after product creation.",
    "Existing SKU save appends media; never creates a duplicate product row.",
    "Products and Media list refresh on focus, no manual reload required.",
    "No orphan media files; saving copies into app media dir.",
    "No secrets, no production API keys, no analytics.",
    "AI features, if any, are optional, editable, and never block save."
  ],
  "buildOrder": [
    "Preserve routes and data invariants",
    "Confirm/extend shared UI primitives only if missing",
    "Build InventoryHeader and use in Products + Media",
    "Rework Camera into capture-first workbench",
    "Rework Capture Preview matching screenshotMap",
    "Rework Products grid + ProductCard",
    "Rework Media grid + MediaTile",
    "Rework Product Detail as SKU workspace",
    "iOS + Android validation pass"
  ]
}
