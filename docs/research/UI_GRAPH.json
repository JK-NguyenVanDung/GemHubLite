    { "file": "docs/research/screenshots/main-creation/03-input-description-move-to-full-screen.png", "use": "Description full-screen consideration", "doNotCopy": ["Full-screen description editor (skip in Lite)"] },
    { "file": "docs/research/screenshots/main-creation/04-select-product-type.png", "use": "Type picker entry", "doNotCopy": ["Hierarchical taxonomy"] },
    { "file": "docs/research/screenshots/main-creation/05-sub-menu-select-type.png", "use": "Subtype concept", "doNotCopy": ["Subtypes"] },
